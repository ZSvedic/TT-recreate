{
  "name": "tamedtable-src",
  "private": true,
  "workspaces": ["packages/*", "tests"],
  "scripts": {
    "setup": "bun install",
    "test": "bun run test:unit && bun run test:headless && bun run test:cli && bun run test:web",
    "test:unit": "bun test packages",
    "test:headless": "bun tests/run-cucumber.ts headless",
    "test:cli": "bun tests/run-cucumber.ts cli",
    "test:web": "bun tests/run-cucumber.ts web",
    "test:record": "TAMEDTABLE_CASSETTE=record bun tests/run-cucumber.ts headless && TAMEDTABLE_CASSETTE=record bun tests/run-cucumber.ts cli",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@duckdb/node-api": "1.4.1-r.2",
    "apache-arrow": "^21.0.0",
    "csv": "^6.4.1"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "@types/node": "^24.3.1"
  }
}

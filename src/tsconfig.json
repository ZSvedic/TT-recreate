{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true
  },
  "include": ["packages/**/*.ts", "tests/**/*.ts"]
}

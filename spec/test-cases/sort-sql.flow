{
  "version": 2,
  "source": "sort-input.csv",
  "spec": {
    "table": "sort-input.csv",
    "columns": [
      { "id": "ID" },
      { "id": "Name" },
      { "id": "Score" }
    ],
    "transformations": [
      {
        "kind": "sort",
        "by": [
          { "key": { "sql": "CAST(Score AS INTEGER)" }, "dir": "desc" }
        ]
      }
    ]
  }
}
